{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Frontend: Dev",
            "type": "shell",
            "command": "source $HOME/.nvm/nvm.sh && nvm use && npm run start",
            "options": {
                "cwd": "${workspaceFolder}/ipwa"
            },
            "presentation": {
                "group": "ipwa-app",
                "panel": "dedicated"
            }
        },
        {
            "label": "Backend: Dev",
            "type": "shell",
            "command": "docker compose up -d mongodb && source $HOME/.nvm/nvm.sh && nvm use && ATLAS_URI=mongodb://localhost:27017/ipwa SECRET=CHANGE_ME npx tsx watch . ; docker compose stop mongodb",
            "options": {
                "cwd": "${workspaceFolder}/ipwa-backend"
            },
            "presentation": {
                "group": "ipwa-app",
                "panel": "dedicated"
            }
        },
        {
            "label": "Start All Services",
            "dependsOrder": "parallel",
            "dependsOn": [
                "Frontend: Dev",
                "Backend: Dev"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}